# University Recruitment Info Collector — Environment Configuration
# Copy this file to .env and adjust values

# --- App ---
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8001

# --- LLM / DeepSeek ---
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_DAILY_LIMIT=200
LLM_MAX_JOBS=20
LLM_TIMEOUT_SECONDS=60

# --- API Security ---
# Comma-separated allowed origins. Leave empty to block all cross-origin in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Set to enable Bearer token auth on /jobs, /match, /collection-runs
API_ACCESS_TOKEN=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=65536

# --- Collection ---
HTTP_CONCURRENCY=5
BROWSER_CONCURRENCY=1
DETAIL_CONCURRENCY=3
COLLECT_TIMEOUT_SECONDS=30
COLLECT_MAX_RETRIES=2

# --- Logging ---
LOG_FORMAT=text
LOG_LEVEL=INFO
