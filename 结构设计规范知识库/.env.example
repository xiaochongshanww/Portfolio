# === API Keys ===

# 智谱AI API密钥（必填，用于文档向量化）
ZHIPUAI_API_KEY=

# DeepSeek API密钥（必填，用于LLM生成回答）
DEEPSEEK_API_KEY=

# === 可选配置 ===

# DeepSeek API 地址（可选，默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# RAG 检索返回的文档数量（可选，默认 10）
RAG_TOP_K=10
