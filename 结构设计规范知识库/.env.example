# === API Keys ===

# 智谱AI API密钥（必填，用于文档向量化和问题向量检索）
ZHIPUAI_API_KEY=

# MiMo API密钥（必填，用于多模态 LLM 生成回答）
MIMO_API_KEY=

# === 可选配置 ===

# MiMo API 地址（可选，默认 https://api.xiaomimimo.com/v1）
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# MiMo 模型名称（可选，默认 mimo-v2-omni）
MIMO_MODEL=mimo-v2-omni

# LLM 请求超时时间，单位秒（可选，默认 180）
LLM_TIMEOUT_SECONDS=180

# RAG 检索返回的文档数量（可选，默认 12）
RAG_TOP_K=12

# 图片加载相关性阈值，距离越小越相关（可选，默认 0.65）
RAG_MIN_SCORE=0.65

# Embedding 模型名称（可选，默认 embedding-2）
EMBEDDING_MODEL=embedding-2

# 检索融合权重（阶段三：dense + BM25 + 条文号精确匹配）
RETRIEVAL_DENSE_WEIGHT=1.0
RETRIEVAL_BM25_WEIGHT=0.18
RETRIEVAL_CLAUSE_BOOST=5.0

# Reranker 扩展点，阶段三默认关闭
RERANK_ENABLED=false
RERANK_PROVIDER=none

# 数据目录（可选，默认项目内 db 和 data/images）
DB_DIR=./db
IMG_DIR=./data/images
IMG_BASE_URL=/images

# 静态页面目录（可选，默认 src/static）
STATIC_DIR=./src/static

# API 鉴权。默认关闭；内部/公网部署建议开启
API_AUTH_ENABLED=false
API_KEYS=

# 请求保护
MAX_REQUEST_BYTES=1048576
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30

# CORS 设置。生产环境应改为明确域名
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=false

# 日志等级
LOG_LEVEL=INFO
