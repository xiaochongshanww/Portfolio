{
  "name": "flask-blog-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/download-openapi.mjs && npm run errors:generate || echo 'codegen skipped (backend may not be running)'",
    "lh": "lighthouse http://localhost:5173/ --preset=mobile --output=json --output-path=./.lighthouse-temp.json",
    "lh:ci": "lhci autorun",
    "lint": "eslint src",
    "format": "prettier --write src/",
    "openapi:download": "node scripts/download-openapi.mjs",
    "openapi:generate": "npm run openapi:download && openapi --input openapi.json --output src/generated --client axios --useUnionTypes true && node scripts/post-generate-patch.mjs",
    "errors:generate": "node scripts/generate-error-codes.mjs",
    "codegen": "npm run openapi:generate && npm run errors:generate",
    "governance:sync": "node scripts/sync-governance.mjs",
    "governance:check": "node scripts/check-governance-drift.mjs",
    "test": "vitest run",
    "test:ui": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.7.2",
    "dompurify": "^3.2.6",
    "echarts": "^5.6.0",
    "element-plus": "^2.10.6",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "lowlight": "^3.3.0",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "pinia": "^2.1.7",
    "shiki": "^3.9.2",
    "turndown": "^7.2.0",
    "vditor": "^3.11.1",
    "vue": "^3.4.31",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@shikijs/markdown-it": "^3.11.0",
    "@tailwindcss/vite": "^4.1.12",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.20.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^26.1.0",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.0",
    "sass-embedded": "^1.91.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.4.5",
    "unplugin-auto-import": "^20.0.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^5.3.3",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.0"
  }
}
